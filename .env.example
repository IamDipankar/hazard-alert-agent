# ── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Cloud TTS ────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_PROJECT_ID=

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hazard_alert
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/hazard_alert

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── ASR Model ───────────────────────────────────────────────────────
ASR_MODEL_NAME=ai4bharat/indic-conformer-600m-multilingual
ASR_DEVICE=cuda
ASR_BATCH_SIZE=1
HF_TOKEN=

# ── Map ─────────────────────────────────────────────────────────────
MAPBOX_TOKEN=

# ── pgvector ────────────────────────────────────────────────────────
PGVECTOR_ENABLED=true

# ── App ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
